      <item>
        <widget class="QStackedWidget" name="mainContentStack">
          <widget class="QWidget" name="pageQuanLyTaiKhoan">
            <property name="styleSheet">
              <string>QWidget#pageQuanLyTaiKhoan { background-color: #f0f4f7; }

/* Profile Card Area */
QFrame#ProfileCard { background-color: white; border-radius: 12px; border: 1px solid #e2e8f0; }
QLabel#AvatarPlaceholder { background-color: #8c8c8c; border-radius: 60px; font-size: 50px; color: white; }
QLabel#UserName { font-size: 22px; font-weight: bold; color: #2d3748; }
QLabel#UserEmail { font-size: 15px; color: #718096; }
QLabel#PillRole { background-color: #ead6d6; color: #b84f4f; border-radius: 15px; padding: 6px 16px; font-weight: bold; font-size: 13px; }
QPushButton#BtnLogout { background-color: #8bbcb9; border: none; border-radius: 15px; padding: 8px 20px; color: white; font-weight: bold; font-size: 13px; }
QPushButton#BtnLogout:hover { background-color: #7aa9a6; }

/* Settings Area */
QFrame#SettingsCard { background-color: #dbe4e4; border-radius: 12px; }
QFrame#SettingsHeader { border-top-left-radius: 12px; border-top-right-radius: 12px; background-color: #0b8480; }

/* Tabs bypassing dynamic properties! Using exact object names! */
QPushButton#tabPersonalInfo, QPushButton#tabSecurity, QPushButton#tabBankInfo { 
    background-color: #c1d5d5; 
    color: white; 
    border-radius: 18px; 
    padding: 10px 20px; 
    font-weight: bold; 
    font-size: 13px; 
    border: none; 
}
QPushButton#tabPersonalInfo:checked, QPushButton#tabSecurity:checked, QPushButton#tabBankInfo:checked { 
    background-color: #8faaa9; 
}
QPushButton#tabPersonalInfo:hover, QPushButton#tabSecurity:hover, QPushButton#tabBankInfo:hover { 
    background-color: #a3c4c4; 
}

QLabel { font-weight: bold; color: #1e293b; font-size: 14px; }

/* Inputs bypassing dynamic properties! Target all within settings card! */
QFrame#SettingsCard QLineEdit, QFrame#SettingsCard QComboBox { 
    background-color: white; 
    border: none; 
    border-radius: 8px; 
    padding: 10px 15px; 
    font-size: 14px; 
    color: #4a5568;
}
QFrame#SettingsCard QLineEdit:focus, QFrame#SettingsCard QComboBox:focus {
    border: 2px solid #0b8480;
}

QComboBox::drop-down {
    border: none;
    width: 30px;
}

/* Update Button */
QPushButton#btnUpdateSettings { 
    background-color: #009688; 
    color: white; 
    border-radius: 8px; 
    padding: 12px 25px; 
    font-weight: bold; 
    font-size: 16px; 
}
QPushButton#btnUpdateSettings:hover {
    background-color: #00796b;
}

/* Radio buttons restored to original */
QRadioButton { font-weight: bold; color: #4a5568; font-size: 14px;}</string>
